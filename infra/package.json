{
  "name": "codeartifact",
  "version": "0.1.0",
  "bin": {
    "codeartifact": "bin/codeartifact.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "deploy-sandbox": "NPM_ENVIRONMENT=sandbox cdk deploy --profile nakom.is-sandbox --all --require-approval never",
    "deploy-prod": "NPM_ENVIRONMENT=prod cdk deploy --profile nakom.is --all --require-approval never",
    "synth-sandbox": "NPM_ENVIRONMENT=sandbox cdk synth --profile nakom.is-sandbox --all",
    "synth-prod": "NPM_ENVIRONMENT=prod cdk synth --profile nakom.is --all",
    "destroy-sandbox": "NPM_ENVIRONMENT=sandbox cdk destroy --profile nakom.is-sandbox --all",
    "destroy-prod": "NPM_ENVIRONMENT=prod cdk destroy --profile nakom.is --all",
    "ci-deploy-sandbox": "NPM_ENVIRONMENT=sandbox cdk deploy --all --require-approval never --output cdk-deploy.out",
    "ci-deploy-prod": "NPM_ENVIRONMENT=prod cdk deploy --all --require-approval never --output cdk-deploy.out",
    "update-dependencies": "npx -y npm-check-updates -u && npm i"
  },
  "dependencies": {
    "aws-cdk-lib": "2.201.0",
    "constructs": "^10.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "22.x",
    "aws-cdk": "^2.1019.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.0"
  }
}
